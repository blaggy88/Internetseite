{
  "name": "edeka-niemerszein",
  "version": "2.0.0",
  "description": "EDEKA Niemerszein - Modernste Supermarkt-Website mit KI-Assistent",
  "main": "index.html",
  "scripts": {
    "start": "serve .",
    "build": "npm run build:css && npm run build:js && npm run build:images",
    "build:css": "postcss styles.css -o dist/styles.min.css --env production",
    "build:js": "terser app.js app_ai.js -o dist/app.min.js --compress --mangle",
    "build:images": "sharp optimize-images",
    "dev": "serve . & npm run watch",
    "watch": "chokidar \"**/*.css\" \"**/*.js\" -c \"npm run build\"",
    "test": "jest",
    "lint": "eslint .",
    "prettier": "prettier --write .",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "keywords": [
    "edeka",
    "supermarkt",
    "ecommerce",
    "ki",
    "ai",
    "shopping",
    "responsive",
    "pwa"
  ],
  "author": "EDEKA Niemerszein",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "chokidar-cli": "^3.0.0",
    "cssnano": "^6.1.2",
    "eslint": "^8.57.0",
    "gh-pages": "^6.1.1",
    "jest": "^29.7.0",
    "postcss": "^8.4.41",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.2.5",
    "serve": "^14.2.3",
    "sharp": "^0.33.2",
    "terser": "^5.31.0"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "Firefox ESR",
    "not dead"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/blaggy88/Internetseite.git"
  },
  "homepage": "https://blaggy88.github.io/Internetseite",
  "bugs": {
    "url": "https://github.com/blaggy88/Internetseite/issues"
  }
}